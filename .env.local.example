# Copy this file to .env.local (which is gitignored) and fill in your real key.
# .env.local is auto-loaded by scripts/*.ps1.
#
# Get a key at https://www.orcarouter.ai/console (starts with sk-orca-).

ORCAROUTER_API_KEY=sk-orca-REPLACE_ME

# Optional: pin a specific live model for testing (default: orcarouter/auto)
# OPENCLAW_LIVE_ORCAROUTER_MODEL=orcarouter/auto
# OPENCLAW_LIVE_ORCAROUTER_MODEL=orcarouter/openai/gpt-5
# OPENCLAW_LIVE_ORCAROUTER_MODEL=orcarouter/anthropic/claude-opus-4.7

# Optional: override the e2e default model if your OrcaRouter workspace has
# not configured the `auto` virtual router. Symptom of needing this:
#   503 No available channel for model auto under group default
# OPENCLAW_E2E_MODEL_AUTO=orcarouter/openai/gpt-4o-mini
